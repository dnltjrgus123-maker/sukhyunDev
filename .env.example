# =============================================================================
# 백엔드(Node API) 환경 변수 — 복사 후 이름을 .env 로 저장
# 경로: 프로젝트 루트/.env  (Git에 올리지 말 것 — .gitignore 에 포함됨)
# 템플릿만 커밋: 이 파일(.env.example)
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE_URL
# 어디서: Supabase → Database → Connection string (Pooler, 예: Session/Transaction, 포트 6543)
# 용도: 런타임(앱)에서 Prisma Client가 쓰는 연결 (풀러 권장)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# -----------------------------------------------------------------------------
# DIRECT_URL
# 어디서: 같은 화면에서 Direct connection (db.<ref>.supabase.co:5432)
# 용도: prisma migrate 등 마이그레이션 전용 — 풀러(transaction)는 migrate에 부적합할 수 있음
#       DIRECT_URL을 쓰는 환경은 IPv4/IPv6로 db 호스트에 직접 닿아야 함 (안 되면 로컬 PC에서 migrate)
# -----------------------------------------------------------------------------
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# -----------------------------------------------------------------------------
# SUPABASE_URL
# 어디서: Project Settings → API → Project URL
# 값 형식: https://[PROJECT_REF].supabase.co
# 용도: 서버에서 Supabase Admin/Anon 클라이언트 생성
# -----------------------------------------------------------------------------
SUPABASE_URL=https://[PROJECT_REF].supabase.co

# -----------------------------------------------------------------------------
# SUPABASE_JWT_SECRET
# 어디서: Project Settings → API → 아래쪽 "JWT 설정" → JWT Secret (문자열)
# 주의: "JWT Signing Keys"(비대칭)만 쓰는 프로젝트는 이 값 없이 SUPABASE_URL JWKS로도 검증됩니다.
# 용도: Authorization: Bearer <access_token> — 먼저 HS256으로 검증, 실패 시 JWKS(비대칭) 폴백
#       JWT Secret·SUPABASE_URL 둘 다 비어 있으면 Bearer 검증을 건너뜀.
# -----------------------------------------------------------------------------
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# SUPABASE_ANON_KEY
# 어디서: Project Settings → API → Project API keys → anon public (긴 JWT)
# 용도: 서버에서 anon 클라이언트(예: 모의 로그인 후 세션 발급) — Node 에만 둠
#       Flutter 는 아래 apps/mobile/dart_defines.json 에 동일 값을 넣음(로컬 전용)
# -----------------------------------------------------------------------------
SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY
# 어디서: Project Settings → API → Project API keys → service_role (긴 JWT)
# 용도: 서버 전용 — Auth Admin API 등. 앱·웹·저장소에 절대 넣지 말 것
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# (선택) 대시보드에 sb_publishable_ / sb_secret_ 형식만 보일 때
# 현재 Node 코드는 읽지 않음. JWT 형태 anon / service_role 위 두 항목을 씁니다.
# 나중에 SDK가 요구하면 여기에 두고 코드에서 읽도록 연결하면 됩니다.
# -----------------------------------------------------------------------------
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=

PORT=4000
# API 바인드. 에뮬레이터만: 127.0.0.1 권장. 실제 기기는 PC LAN IP + LISTEN_HOST=0.0.0.0
LISTEN_HOST=0.0.0.0
AUTH_MODE=hybrid
# hybrid 에서 Bearer/x-user-id 없을 때 쓰는 개발용 UUID (시드 member1 과 맞출 것)
DEV_ACTOR_USER_ID=00000000-0000-4000-8000-000000000002
ALLOW_MOCK_SOCIAL=true

# =============================================================================
# Flutter (apps/mobile) — Supabase 는 여기 넣지 말고 아래 파일 참고
# 경로: apps/mobile/dart_defines.json.example 를 복사 → dart_defines.json
#       (dart_defines.json 은 .gitignore — 커밋 금지)
# 실행: flutter run --dart-define-from-file=dart_defines.json
#       또는 VS Code → .vscode/launch.json 의 Flutter 구성
# Flutter 에 넣는 키: SUPABASE_URL, SUPABASE_ANON_KEY 만 (service_role·JWT Secret 금지)
# =============================================================================
